# 1. Disable Directory Browsing (Critical to prevent file inspection)
Options -Indexes

# 2. Prevent Common Sensitive File Leaks
<FilesMatch "^\.|\.(config|ini|log|sh|sql|bak|swp|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 3. Block access to system/dev folders & Handle Authorization Header
RewriteEngine On
RewriteRule ^(vendor|debug|scripts|logs|ci|\.git)/ - [F,L]

# Pass Authorization Header to PHP (Needed for Bearer tokens on many Apache setups)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# 4. Enforce UTF-8 and Security (if mod_headers is enabled)
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
